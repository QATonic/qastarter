# EditorConfig — keeps formatting consistent across editors and OSes.
# https://editorconfig.org/
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown allows trailing whitespace for hard line breaks
[*.md]
trim_trailing_whitespace = false

# Makefiles must use tabs
[Makefile]
indent_style = tab

# Shell scripts — keep LF even on Windows checkouts
[*.{sh,bash}]
end_of_line = lf

# Windows batch files — must keep CRLF
[*.{bat,cmd}]
end_of_line = crlf

# Java / Kotlin / Gradle — community standard is 4-space indent, but our
# templates use 4-space *.java/*.kt and 2-space build.gradle, mirror that.
[*.{java,kt}]
indent_size = 4

[*.{py}]
indent_size = 4

[*.{go}]
indent_style = tab

# Don't try to lint binaries
[*.{jar,war,png,jpg,jpeg,gif,ico,pdf,zip}]
charset = unset
end_of_line = unset
insert_final_newline = false
trim_trailing_whitespace = false
indent_style = unset
indent_size = unset
