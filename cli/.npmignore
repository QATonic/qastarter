# Source files - only publish compiled output
src/
*.ts

# Declaration files — this is a CLI, not a library. Users invoke `qastarter`,
# they don't `import` from us. Dropping .d.ts shaves ~15% off the tarball.
*.d.ts
*.d.ts.map

# Development config
tsconfig.json
.eslintrc*
.prettierrc*

# Build artifacts
node_modules/
.git/
.gitignore
*.log

# Test files
*.test.ts
*.spec.ts
__tests__/
coverage/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
