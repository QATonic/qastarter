version: 2.1

executors:
  gradle-executor:
    docker:
      - image: cimg/openjdk:11.0
    working_directory: ~/project
    environment:
      GRADLE_OPTS: -Xmx1024m

jobs:
  test:
    executor: gradle-executor
    parameters:
      environment:
        type: string
        default: "qa"
    steps:
      - checkout

      - restore_cache:
          keys:
            - gradle-repo-v1-{{ checksum "build.gradle" }}
            - gradle-repo-v1-

      - run:
          name: Install dependencies
          command: ./gradlew dependencies --no-daemon

      - save_cache:
          paths:
            - ~/.gradle
          key: gradle-repo-v1-{{ checksum "build.gradle" }}

      - run:
          name: Run {{#if (eq testingPattern "bdd")}}Cucumber BDD{{else}}TestNG{{/if}} tests
          command: |
            ./gradlew clean test {{#if (eq testingPattern "bdd")}}-Dincludes="**/runners/*TestRunner.java"{{else}}-Denvironment=<<parameters.environment>>{{/if}} --no-daemon
          environment:
            ENVIRONMENT: <<parameters.environment>>

      {{#if (eq reportingTool "allure")}}
      - run:
          name: Install Allure CLI
          command: |
            wget https://github.com/allure-framework/allure2/releases/download/2.25.0/allure-2.25.0.tgz
            tar -zxvf allure-2.25.0.tgz -C /opt/
            sudo ln -s /opt/allure-2.25.0/bin/allure /usr/local/bin/allure
          when: always

      - run:
          name: Generate Allure report
          command: |
            allure generate build/allure-results --clean -o allure-report
          when: always

      - store_artifacts:
          path: build/allure-results
          destination: allure-results-<<parameters.environment>>

      - store_artifacts:
          path: allure-report
          destination: allure-report-<<parameters.environment>>
      {{/if}}

      {{#if (eq reportingTool "extent-reports")}}
      - store_artifacts:
          path: test-output/extent-reports
          destination: extent-reports-<<parameters.environment>>
      {{/if}}

      {{#if (eq reportingTool "testng-reports")}}
      - store_artifacts:
          path: build/reports/tests
          destination: testng-reports-<<parameters.environment>>
      {{/if}}

      {{#if (eq reportingTool "junit-html")}}
      - store_artifacts:
          path: build/reports/tests
          destination: junit-html-reports-<<parameters.environment>>
      {{/if}}

      - store_test_results:
          path: build/test-results

workflows:
  test-workflow:
    jobs:
      - test:
          name: "Test QA Environment"
          environment: "qa"
      - test:
          name: "Test Dev Environment"
          environment: "dev"
