plugins {
    id 'java'
{{#if (eq reportingTool "allure")}}
    id 'io.qameta.allure' version '{{toolVersions.allure}}'
{{/if}}
}

group = '{{groupId}}'
version = '1.0.0'
sourceCompatibility = '17'

repositories {
    mavenCentral()
}

dependencies {
    // RestAssured
    implementation 'io.rest-assured:rest-assured:{{toolVersions.restassured}}'
    implementation 'io.rest-assured:json-path:{{toolVersions.restassured}}'
    implementation 'io.rest-assured:json-schema-validator:{{toolVersions.restassured}}'
    
    // TestNG
    implementation 'org.testng:testng:{{toolVersions.testng}}'
    
    // JSON
    implementation 'com.google.code.gson:gson:{{toolVersions.gson}}'
    implementation 'com.fasterxml.jackson.core:jackson-databind:{{toolVersions.jackson}}'
    implementation 'com.jayway.jsonpath:json-path:2.9.0'
    
{{#if (eq reportingTool "allure")}}
    // Allure
    implementation 'io.qameta.allure:allure-testng:{{toolVersions.allure}}'
{{/if}}

    // Logging
    implementation 'org.slf4j:slf4j-simple:2.0.9'
{{#if userDependencies.hasMaven}}

// User-picked dependencies (from QAStarter dependency search)
{{#each userDependencies.maven}}
implementation '{{group}}:{{name}}:{{version}}'
{{/each}}
{{/if}}
    {{#if utilities.faker}}
    // DataFaker — Test data generation
    implementation 'net.datafaker:datafaker:{{toolVersions.datafaker}}'
    {{/if}}
}

test {
    useTestNG()
    testLogging {
        events "passed", "skipped", "failed"
    }
}