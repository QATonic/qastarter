{
  "id": "api-typescript-grpc-jest-npm",
  "displayName": "TypeScript gRPC API Framework",
  "description": "Professional gRPC API automation framework with TypeScript, @grpc/grpc-js, Jest, and npm",
  "version": "2.0.0",
  "supportsDynamic": true,
  "supportedCombination": {
    "testingType": "api",
    "framework": "grpc",
    "language": "typescript",
    "testRunner": "jest",
    "buildTool": "npm"
  },
  "toolVersions": {
    "node": "18+",
    "grpc-js": "1.9.0",
    "jest": "29.7.0",
    "typescript": "5.3.0"
  },
  "files": [
    {
      "path": ".gitignore",
      "isTemplate": false,
      "description": "Git ignore rules"
    },
    {
      "path": "package.json",
      "isTemplate": true,
      "description": "Node.js package configuration"
    },
    {
      "path": "tsconfig.json",
      "isTemplate": true,
      "description": "TypeScript configuration"
    },
    {
      "path": "jest.config.ts",
      "isTemplate": true,
      "description": "Jest configuration"
    },
    {
      "path": "README.md",
      "isTemplate": true,
      "description": "Project documentation"
    },
    {
      "path": "Jenkinsfile",
      "isTemplate": true,
      "conditional": {
        "cicdTool": "jenkins"
      },
      "description": "Jenkins pipeline"
    },
    {
      "path": "Dockerfile",
      "isTemplate": true,
      "conditional": {
        "utilities.includeDocker": true
      },
      "description": "Docker configuration"
    },
    {
      "path": "config/ConfigReader.ts",
      "isTemplate": true,
      "description": "Configuration reader"
    },
    {
      "path": "core/GrpcClient.ts",
      "isTemplate": true,
      "description": "gRPC client wrapper"
    },
    {
      "path": "protos/user.proto",
      "isTemplate": true,
      "description": "User protobuf definition"
    },
    {
      "path": "protos/common.proto",
      "isTemplate": true,
      "description": "Common protobuf definitions"
    },
    {
      "path": "utils/Logger.ts",
      "isTemplate": true,
      "description": "Logging utility"
    },
    {
      "path": "tests/setup.ts",
      "isTemplate": true,
      "description": "Jest test setup"
    },
    {
      "path": "tests/GrpcTests.spec.ts",
      "isTemplate": true,
      "description": "gRPC API tests"
    },
    {
      "path": "utils/testDataFactory.ts",
      "isTemplate": true,
      "conditional": {
        "utilities.faker": true
      }
    },
    {
      "path": "tests/openapi.test.ts",
      "isTemplate": true,
      "conditional": {
        "hasOpenApiEndpoints": true
      }
    }
  ],
  "directories": [
    "logs",
    "reports",
    "protos"
  ],
  "dynamicSupport": {
    "reportingTools": [
      "allure"
    ],
    "cicdTools": [
      "jenkins"
    ],
    "testingPatterns": []
  }
}
