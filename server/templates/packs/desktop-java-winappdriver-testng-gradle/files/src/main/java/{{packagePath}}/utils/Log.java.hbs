package {{javaPackage}}.utils;

import java.io.File;
import java.io.FileWriter;
import java.io.PrintWriter;
import java.text.SimpleDateFormat;
import java.util.Date;

public class Log {
    private static final String LOG_DIR = "logs";
    private static PrintWriter logWriter;
    private static final SimpleDateFormat dateFormat = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss");

    static {
        try {
            new File(LOG_DIR).mkdirs();
            String timestamp = new SimpleDateFormat("yyyy-MM-dd_HH-mm-ss").format(new Date());
            logWriter = new PrintWriter(new FileWriter(LOG_DIR + "/desktop_test_" + timestamp + ".log", true));
        } catch (Exception e) { System.err.println("[Log] Failed: " + e.getMessage()); }
    }

    private static void log(String level, String message) {
        String logLine = String.format("%s | %-8s | %s", dateFormat.format(new Date()), level, message);
        System.out.println(logLine);
        if (logWriter != null) { logWriter.println(logLine); logWriter.flush(); }
    }

    public static void info(String message) { log("INFO", message); }
    public static void warn(String message) { log("WARN", message); }
    public static void debug(String message) { log("DEBUG", message); }
    public static void error(String message) { log("ERROR", message); }
    public static void error(String message, Throwable t) { log("ERROR", message + " — " + (t != null ? t.toString() : "")); }
    public static void step(String message) { log("STEP", message); }
    public static void screenshot(String path) { log("SCREEN", "Saved: " + path); }
    public static void startSuite(String name) { log("SUITE", "START " + name); }
    public static void endSuite(String name) { log("SUITE", "END " + name); }
    public static void startTest(String name) { log("TEST", "START " + name); }
    public static void endTest(String name, String status) { log("TEST", "END " + name + " [" + status + "]"); }
    public static void performance(String label, long millis) { log("PERF", label + " took " + millis + "ms"); }
}