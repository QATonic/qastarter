<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    {{#if utilities.faker}}
    <!-- Bogus — Test data generation -->
    <PackageReference Include="Bogus" Version="{{toolVersions.bogus}}" />
    {{/if}}
    <PackageReference Include="Appium.WebDriver" Version="5.0.0" />
    <PackageReference Include="Selenium.WebDriver" Version="4.25.0" />
    <PackageReference Include="DotNetSeleniumExtras.WaitHelpers" Version="3.11.0" />
    <PackageReference Include="NUnit" Version="4.0.1" />
    <PackageReference Include="NUnit3TestAdapter" Version="4.5.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="8.0.0" />
    <PackageReference Include="FluentAssertions" Version="6.12.0" />
{{#if (eq cloudDeviceFarm "browserstack")}}
    <!-- BrowserStack SDK — reads browserstack.yml at project root and
         auto-instruments Appium sessions to route to BrowserStack's App
         Automate cloud. Upload your .apk / .ipa first with:
           curl -u "$BROWSERSTACK_USERNAME:$BROWSERSTACK_ACCESS_KEY" \
                -X POST "https://api-cloud.browserstack.com/app-automate/upload" \
                -F "file=@/path/to/app.apk"
         then paste the returned app_url into browserstack.yml (bs://...).
         Set BROWSERSTACK_USERNAME + BROWSERSTACK_ACCESS_KEY env vars before
         running `dotnet test`. No C# code changes required. -->
    <PackageReference Include="BrowserStack.TestAdapter" Version="0.28.1" />
{{/if}}
  </ItemGroup>
{{#if (eq cloudDeviceFarm "browserstack")}}

  <ItemGroup>
    <None Update="browserstack.yml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>
{{/if}}
</Project>