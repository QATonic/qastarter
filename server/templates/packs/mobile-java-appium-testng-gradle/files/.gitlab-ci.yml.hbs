image: gradle:8.5-jdk{{toolVersions.java}}

variables:
  GRADLE_OPTS: "-Dorg.gradle.daemon=false"

cache:
  paths:
    - .gradle/

stages:
  - test
  - report

before_script:
  - apt-get update -qq
  - apt-get install -y nodejs npm curl
  - npm install -g appium@{{toolVersions.appium}}
  - appium driver install uiautomator2
  {{#if (eq reportingTool "allure")}}
  - curl -o allure-{{toolVersions.allure}}.tgz -L https://github.com/allure-framework/allure2/releases/download/{{toolVersions.allure}}/allure-{{toolVersions.allure}}.tgz
  - tar -zxvf allure-{{toolVersions.allure}}.tgz -C /opt/
  - ln -s /opt/allure-{{toolVersions.allure}}/bin/allure /usr/bin/allure
  {{/if}}

test:android:
  stage: test
  script:
    - ./gradlew clean test -Pandroid
  artifacts:
    when: always
    paths:
      {{#if (eq reportingTool "allure")}}
      - build/allure-results/
      {{/if}}
      {{#if (eq reportingTool "extent-reports")}}
      - reports/
      {{/if}}
      {{#if (eq reportingTool "testng-reports")}}
      - test-output/
      {{/if}}
      {{#if (eq reportingTool "junit-reports")}}
      - build/reports/tests/
      {{/if}}
      - logs/
    expire_in: 30 days
  allow_failure: false

test:ios:
  stage: test
  script:
    - ./gradlew clean test -Pios
  artifacts:
    when: always
    paths:
      {{#if (eq reportingTool "allure")}}
      - build/allure-results/
      {{/if}}
      {{#if (eq reportingTool "extent-reports")}}
      - reports/
      {{/if}}
      {{#if (eq reportingTool "testng-reports")}}
      - test-output/
      {{/if}}
      {{#if (eq reportingTool "junit-reports")}}
      - build/reports/tests/
      {{/if}}
      - logs/
    expire_in: 30 days
  allow_failure: false

{{#if (eq reportingTool "allure")}}
generate-report:
  stage: report
  dependencies:
    - test:android
    - test:ios
  script:
    - allure generate build/allure-results --clean -o build/allure-report
  artifacts:
    paths:
      - build/allure-report/
    expire_in: 30 days
{{/if}}

{{#if (eq reportingTool "junit-reports")}}
generate-junit-report:
  stage: report
  dependencies:
    - test:android
    - test:ios
  script:
    - ./gradlew testReport
  artifacts:
    paths:
      - build/reports/tests/
    expire_in: 30 days
{{/if}}
