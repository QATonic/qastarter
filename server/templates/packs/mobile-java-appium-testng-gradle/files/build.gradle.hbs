plugins {
    id 'java'
}

group = '{{groupId}}'
version = '1.0.0'
sourceCompatibility = '17'

repositories {
    mavenCentral()
}

dependencies {
    // Appium
    implementation 'io.appium:java-client:{{toolVersions.appium}}'
    
    // Selenium
    implementation 'org.seleniumhq.selenium:selenium-java:{{toolVersions.selenium}}'
    
    // TestNG
    implementation 'org.testng:testng:{{toolVersions.testng}}'
    
    // Logging
    implementation 'org.slf4j:slf4j-simple:2.0.9'

    // ExtentReports (used by TestListener)
    implementation 'com.aventstack:extentreports:5.1.1'
    // Allure (used by AllureManager)
    implementation 'io.qameta.allure:allure-testng:2.24.0'
    // File utilities (used by ScreenshotUtils)
    implementation 'commons-io:commons-io:2.15.1'
{{#if userDependencies.hasMaven}}

// User-picked dependencies (from QAStarter dependency search)
{{#each userDependencies.maven}}
implementation '{{group}}:{{name}}:{{version}}'
{{/each}}
{{/if}}
    {{#if utilities.faker}}
    // DataFaker — Test data generation
    implementation 'net.datafaker:datafaker:{{toolVersions.datafaker}}'
    {{/if}}
{{#if (eq cloudDeviceFarm "browserstack")}}

    // BrowserStack SDK — auto-instruments Appium sessions to route to
    // BrowserStack's App Automate cloud based on browserstack.yml at project root.
    // Upload your .apk / .ipa first with:
    //   curl -u "$BROWSERSTACK_USERNAME:$BROWSERSTACK_ACCESS_KEY" \
    //        -X POST "https://api-cloud.browserstack.com/app-automate/upload" \
    //        -F "file=@/path/to/app.apk"
    // then paste the returned app_url into browserstack.yml (bs://...).
    implementation 'com.browserstack:browserstack-java-sdk:1.25.0'
{{/if}}
}

test {
    useTestNG()
    testLogging {
        events "passed", "skipped", "failed"
    }
{{#if (eq cloudDeviceFarm "browserstack")}}

    // Attach BrowserStack SDK as a java agent so every Appium session
    // routes to BrowserStack based on browserstack.yml.
    doFirst {
        def sdkJar = configurations.testRuntimeClasspath.find { it.name.startsWith('browserstack-java-sdk') }
        if (sdkJar != null) {
            jvmArgs += ["-javaagent:${sdkJar.absolutePath}"]
        }
    }
{{/if}}
}