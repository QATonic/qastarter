# BrowserStack App Automate Configuration for {{projectName}}
# Docs: https://www.browserstack.com/docs/app-automate/appium

userName: BROWSERSTACK_USERNAME
accessKey: BROWSERSTACK_ACCESS_KEY

app: bs://YOUR_APP_HASH

platforms:
  - deviceName: Samsung Galaxy S23
    platformName: android
    platformVersion: "13.0"
  - deviceName: Google Pixel 7
    platformName: android
    platformVersion: "13.0"
  - deviceName: iPhone 14
    platformName: ios
    platformVersion: "16"

buildName: "{{projectName}} - Build #1"
projectName: "{{projectName}}"
debug: true
networkLogs: true
