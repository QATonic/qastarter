"""
Login Tests — SauceDemo mobile app.

Run: pytest tests/ -v

The `driver` fixture is provided by conftest.py at the project root.
"""
import json
from pathlib import Path
import pytest
from tests.pages.login_page import LoginPage


_DATA_FILE = Path(__file__).resolve().parent.parent / "data" / "users.json"


def _load_users():
    if not _DATA_FILE.exists():
        return []
    return [
        (u["username"], u["password"], u["expected"])
        for u in json.loads(_DATA_FILE.read_text())
    ]


class TestLogin:
    VALID_USER = "standard_user"
    VALID_PASS = "secret_sauce"

    @pytest.mark.smoke
    def test_valid_login(self, driver):
        """Verify successful login with valid credentials."""
        login_page = LoginPage(driver)
        login_page.login(self.VALID_USER, self.VALID_PASS)
        assert login_page.is_login_successful(), "Should navigate to Products"

    @pytest.mark.regression
    def test_invalid_login(self, driver):
        """Verify error message with invalid credentials."""
        login_page = LoginPage(driver)
        login_page.login("invalid_user", "wrong_password")
        assert login_page.is_error_displayed(), "Should show error message"

    {{#if utilities.dataProvider}}
    @pytest.mark.regression
    @pytest.mark.parametrize("username,password,expected", _load_users())
    def test_login_with_data(self, driver, username, password, expected):
        """Data-driven login test using data/users.json."""
        login_page = LoginPage(driver)
        login_page.login(username, password)

        if expected == "success":
            assert login_page.is_login_successful(), (
                f"Login should succeed for: {username}"
            )
        else:
            assert login_page.is_error_displayed(), (
                f"Error should display for: {username}"
            )
    {{/if}}
