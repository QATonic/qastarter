name: Gatling Performance Tests

on:
  workflow_dispatch:
    inputs:
      simulation:
        description: 'Simulation class to run'
        required: true
        default: 'LoadSimulation'
        type: choice
        options:
          - LoadSimulation
          - StressSimulation

jobs:
  performance-test:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK {{toolVersions.java}}
        uses: actions/setup-java@v4
        with:
          java-version: '{{toolVersions.java}}'
          distribution: 'temurin'
          cache: maven

      - name: Run Gatling Simulation
        run: |
          mvn gatling:test -Dgatling.simulationClass={{javaPackage}}.simulations.{{raw}}${{ github.event.inputs.simulation }}{{/raw}}

      - name: Upload Gatling Report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: gatling-report
          path: target/gatling/
          retention-days: 14
