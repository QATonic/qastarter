import http from 'k6/http';
import { check, sleep } from 'k6';
import { BASE_URL, defaultHeaders } from './helpers/utils.js';

/**
 * Stress Test — pushes the system beyond normal capacity.
 *
 * Gradually increases load to find the breaking point.
 * Identifies how the system degrades under heavy traffic.
 */
export const options = {
  stages: [
    { duration: '2m', target: 100 },   // ramp to 100 users
    { duration: '3m', target: 100 },   // hold at 100
    { duration: '2m', target: 200 },   // push to 200
    { duration: '3m', target: 200 },   // hold at 200
    { duration: '2m', target: 0 },     // ramp down
  ],
  thresholds: {
    http_req_duration: ['p(95)<1000', 'p(99)<3000'],
    http_req_failed: ['rate<0.05'],
  },
};

export default function () {
  const res = http.get(`${BASE_URL}`, { headers: defaultHeaders });

  check(res, {
    'status is 200': (r) => r.status === 200,
    'response time < 1s': (r) => r.timings.duration < 1000,
  });

  sleep(0.5);
}
