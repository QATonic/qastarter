# ============================================================
#                    QUICK SETUP GUIDE
# ============================================================
# 
# STEP 1: Update the values below with your website details
{{#if (eq buildTool 'gradle')}}
# STEP 2: Run: gradle clean test
# STEP 3: View reports in build/reports/ folder
{{else}}
# STEP 2: Run: mvn clean test
# STEP 3: View reports in target/surefire-reports/ folder
{{/if}}
#
# ============================================================

# ========== CHANGE THESE VALUES ==========

# Your website URL (e.g., https://mywebsite.com)
BASE_URL={{baseUrl}}

# Login credentials for testing
TEST_USERNAME={{testUsername}}
TEST_PASSWORD={{testPassword}}

# ==========================================

# Browser settings (chrome, firefox, edge)
BROWSER=chrome

# Run tests without opening browser window (true/false)
HEADLESS=false

# Environment (dev, qa, prod)
ENVIRONMENT=dev

# Wait timeout in seconds
TIMEOUT=10
