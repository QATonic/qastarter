<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>{{groupId}}</groupId>
    <artifactId>{{artifactId}}</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>{{projectName}}</name>
    <description>UI Automation Framework using Selenium WebDriver, TestNG, and Maven</description>

    <properties>
        <maven.compiler.source>{{toolVersions.java}}</maven.compiler.source>
        <maven.compiler.target>{{toolVersions.java}}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- Dependency Versions -->
        <selenium.version>{{toolVersions.selenium}}</selenium.version>
        <testng.version>{{toolVersions.testng}}</testng.version>
        <log4j.version>{{toolVersions.log4j}}</log4j.version>
        {{#if (eq reportingTool "extent-reports")}}
        <extentreports.version>{{toolVersions.extentreports}}</extentreports.version>
        {{/if}}
        {{#if (eq reportingTool "allure")}}
        <allure.version>{{toolVersions.allure}}</allure.version>
        <aspectj.version>1.9.20</aspectj.version>
        {{/if}}
        {{#if (eq testingPattern "bdd")}}
        <cucumber.version>{{toolVersions.cucumber}}</cucumber.version>
        {{/if}}
        <jackson.version>2.15.2</jackson.version>
        <commons-csv.version>1.10.0</commons-csv.version>

        <!-- Plugin Versions -->
        <maven-compiler-plugin.version>3.11.0</maven-compiler-plugin.version>
        <maven-surefire-plugin.version>3.1.2</maven-surefire-plugin.version>
        <maven-failsafe-plugin.version>3.1.2</maven-failsafe-plugin.version>

        <!-- Test Configuration -->
        <suite>testng.xml</suite>
        <browser>chrome</browser>
        <headless>false</headless>
        <env>dev</env>
    </properties>

    <dependencies>
        <!-- Selenium WebDriver -->
        <dependency>
            <groupId>org.seleniumhq.selenium</groupId>
            <artifactId>selenium-java</artifactId>
            <version>${selenium.version}</version>
        </dependency>

        <!-- TestNG -->
        <dependency>
            <groupId>org.testng</groupId>
            <artifactId>testng</artifactId>
            <version>${testng.version}</version>
        </dependency>
        {{#if (eq testingPattern "bdd")}}

        <!-- Cucumber -->
        <dependency>
            <groupId>io.cucumber</groupId>
            <artifactId>cucumber-java</artifactId>
            <version>${cucumber.version}</version>
        </dependency>
        <dependency>
            <groupId>io.cucumber</groupId>
            <artifactId>cucumber-testng</artifactId>
            <version>${cucumber.version}</version>
        </dependency>
        {{/if}}
        {{#if (eq reportingTool "extent-reports")}}

        <!-- ExtentReports -->
        <dependency>
            <groupId>com.aventstack</groupId>
            <artifactId>extentreports</artifactId>
            <version>${extentreports.version}</version>
        </dependency>
        {{/if}}
        {{#if (eq reportingTool "allure")}}

        <!-- Allure -->
        <dependency>
            <groupId>io.qameta.allure</groupId>
            <artifactId>allure-testng</artifactId>
            <version>${allure.version}</version>
        </dependency>
        {{#if (eq testingPattern "bdd")}}
        <dependency>
            <groupId>io.qameta.allure</groupId>
            <artifactId>allure-cucumber7-jvm</artifactId>
            <version>${allure.version}</version>
        </dependency>
        {{/if}}
        {{/if}}


        <!-- Log4j2 -->
        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-core</artifactId>
            <version>${log4j.version}</version>
        </dependency>
        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-api</artifactId>
            <version>${log4j.version}</version>
        </dependency>

        <!-- JSON Processing -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>${jackson.version}</version>
        </dependency>

        <!-- CSV Processing -->
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-csv</artifactId>
            <version>${commons-csv.version}</version>
        </dependency>
        {{#if (eq cloudDeviceFarm "browserstack")}}

        <!-- BrowserStack SDK — auto-instruments Selenium tests to run on
             BrowserStack's cloud based on config/browserstack.yml. Set
             BROWSERSTACK_USERNAME + BROWSERSTACK_ACCESS_KEY env vars
             (or pass via -Dbrowserstack.username / -Dbrowserstack.accessKey)
             before running. No Java code changes required. -->
        <dependency>
            <groupId>com.browserstack</groupId>
            <artifactId>browserstack-java-sdk</artifactId>
            <version>1.25.0</version>
            <scope>compile</scope>
        </dependency>
        {{/if}}
        {{#if (eq cloudDeviceFarm "saucelabs")}}

        <!-- Sauce Labs JUnit5 / TestNG reporting bridge. Tests must use
             `RemoteWebDriver(new URL("https://ondemand.saucelabs.com/wd/hub"), caps)`
             with SAUCE_USERNAME + SAUCE_ACCESS_KEY env vars. -->
        <dependency>
            <groupId>com.saucelabs</groupId>
            <artifactId>sauce_testng</artifactId>
            <version>2.1.25</version>
        </dependency>
        {{/if}}
        {{#if userDependencies.hasMaven}}

        <!-- User-picked dependencies (from QAStarter dependency search) -->
        {{#each userDependencies.maven}}
        <dependency>
            <groupId>{{group}}</groupId>
            <artifactId>{{name}}</artifactId>
            <version>{{version}}</version>
        </dependency>
        {{/each}}
        {{/if}}
        {{#if utilities.faker}}
        <!-- DataFaker — Test data generation -->
        <dependency>
            <groupId>net.datafaker</groupId>
            <artifactId>datafaker</artifactId>
            <version>{{toolVersions.datafaker}}</version>
        </dependency>
        {{/if}}
    </dependencies>

    <build>
        <plugins>
            <!-- Compiler Plugin -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven-compiler-plugin.version}</version>
                <configuration>
                    <source>${maven.compiler.source}</source>
                    <target>${maven.compiler.target}</target>
                </configuration>
            </plugin>
            {{#if (eq cloudDeviceFarm "browserstack")}}

            <!-- Dependency Plugin — populates `${com.browserstack:browserstack-java-sdk:jar}`
                 so Surefire can attach the BrowserStack SDK as a java agent. The agent
                 hooks Selenium's RemoteWebDriver / ChromeDriver / FirefoxDriver builders
                 to route sessions to BrowserStack's cloud per config/browserstack.yml. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>3.6.1</version>
                <executions>
                    <execution>
                        <id>getClasspathFilenames</id>
                        <goals>
                            <goal>properties</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            {{/if}}

            <!-- Surefire Plugin for Test Execution -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${maven-surefire-plugin.version}</version>
                <configuration>
                    <suiteXmlFiles>
                        <suiteXmlFile>src/test/resources/${suite}</suiteXmlFile>
                    </suiteXmlFiles>
                    <systemPropertyVariables>
                        <browser>${browser}</browser>
                        <headless>${headless}</headless>
                        <env>${env}</env>
                    </systemPropertyVariables>
                    <useSystemClassLoader>false</useSystemClassLoader>
                    <argLine>-Dfile.encoding=UTF-8{{#if (eq reportingTool "allure")}}
                        -javaagent:"${settings.localRepository}/org/aspectj/aspectjweaver/${aspectj.version}/aspectjweaver-${aspectj.version}.jar"{{/if}}{{#if (eq cloudDeviceFarm "browserstack")}}
                        -javaagent:"${com.browserstack:browserstack-java-sdk:jar}"{{/if}}
                    </argLine>
                </configuration>
                {{#if (eq reportingTool "allure")}}
                <dependencies>
                    <dependency>
                        <groupId>org.aspectj</groupId>
                        <artifactId>aspectjweaver</artifactId>
                        <version>${aspectj.version}</version>
                    </dependency>
                </dependencies>
                {{/if}}
            </plugin>
            <plugin>
                <groupId>com.diffplug.spotless</groupId>
                <artifactId>spotless-maven-plugin</artifactId>
                <version>2.43.0</version>
                <configuration>
                    <java>
                        <googleJavaFormat>
                            <version>1.17.0</version>
                            <style>
                                AOSP
                            </style>
                        </googleJavaFormat>
                    </java>
                </configuration>
            </plugin>
            {{#if (eq reportingTool "allure")}}

            <!-- Allure Maven Plugin -->
            <plugin>
                <groupId>io.qameta.allure</groupId>
                <artifactId>allure-maven</artifactId>
                <version>2.12.0</version>
                <configuration>
                    <reportVersion>${allure.version}</reportVersion>
                    <resultsDirectory>${project.basedir}/reports/allure-results</resultsDirectory>
                </configuration>
            </plugin>
            {{/if}}
        </plugins>
    </build>

    <profiles>
        <!-- Development Environment -->
        <profile>
            <id>dev</id>
            <properties>
                <env>dev</env>
            </properties>
        </profile>

        <!-- QA Environment -->
        <profile>
            <id>qa</id>
            <properties>
                <env>qa</env>
            </properties>
        </profile>

        <!-- Staging Environment -->
        <profile>
            <id>stg</id>
            <properties>
                <env>stg</env>
            </properties>
        </profile>

        <!-- Production Environment -->
        <profile>
            <id>prod</id>
            <properties>
                <env>prod</env>
            </properties>
        </profile>

        <!-- Headless Execution -->
        <profile>
            <id>headless</id>
            <properties>
                <headless>true</headless>
            </properties>
        </profile>

        <!-- Different Browser Profiles -->
        <profile>
            <id>chrome</id>
            <properties>
                <browser>chrome</browser>
            </properties>
        </profile>

        <profile>
            <id>firefox</id>
            <properties>
                <browser>firefox</browser>
            </properties>
        </profile>

        <profile>
            <id>edge</id>
            <properties>
                <browser>edge</browser>
            </properties>
        </profile>
    </profiles>
</project>