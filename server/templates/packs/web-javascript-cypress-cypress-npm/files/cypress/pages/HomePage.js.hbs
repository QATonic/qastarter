const { BasePage } = require('./BasePage');

class HomePage extends BasePage {
  constructor() {
    super();
    this.welcomeMessage = '.welcome-message, h1';
    this.userProfile = '.user-profile';
    this.logoutButton = 'button[data-action="logout"], .logout';
  }

  visitHomePage(baseUrl) {
    return this.visit(baseUrl);
  }

  verifyUserProfileVisible() {
    return this.shouldBeVisible(this.userProfile);
  }

  logout() {
    this.click(this.logoutButton);
    cy.url().should('include', '/login');
    return this;
  }
}

module.exports = { HomePage };
