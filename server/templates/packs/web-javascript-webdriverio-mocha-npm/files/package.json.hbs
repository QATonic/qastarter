{
  "name": "{{artifactId}}",
  "version": "1.0.0",
  "type": "module",
  "description": "WebdriverIO test automation framework with Mocha",
  "scripts": {
    "wdio": "wdio run ./wdio.conf.js",
    "test": "wdio run ./wdio.conf.js",
    "lint": "eslint .",
    "format": "prettier --write ."
