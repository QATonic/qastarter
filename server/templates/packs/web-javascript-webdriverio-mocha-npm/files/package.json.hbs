    {{/if}}
    "@wdio/cli": "^8.27.0",
    "@wdio/local-runner": "^8.27.0",
    "@wdio/mocha-framework": "^8.27.0",
    "@wdio/spec-reporter": "^8.27.0",
    "eslint": "^8.56.0",
    "eslint-plugin-wdio": "^8.24.0",
    "prettier": "^3.2.4"
    {{#if (eq reportingTool "allure")}},"@wdio/allure-reporter": "^8.27.0"{{/if}}
    {{#if (eq cloudDeviceFarm "browserstack")}},"@wdio/browserstack-service": "^8.40.3"{{/if}}
  }
}
