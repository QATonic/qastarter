{
"name": "{{artifactId}}",
"version": "1.0.0",
"description": "{{projectName}} - Playwright TypeScript Automation Framework",
"scripts": {
"test": "{{#if (eq cloudDeviceFarm "browserstack")}}browserstack-node-sdk jest{{else}}jest{{/if}}",
"test:local": "jest",
"test:headed": "HEADLESS=false jest",
"test:parallel": "jest --maxWorkers=4",
{{#if (eq reportingTool "allure")}}
"report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
{{/if}}
"lint": "eslint .",
"format": "prettier --write ."
},
"dependencies": {
"playwright": "^1.41.0",
"dotenv": "^16.3.0"
},
"devDependencies": { {{!-- User-picked deps from QAStarter dependency search --}}{{#each userDependencies.npm}}"{{name}}": "{{version}}",{{/each}}
{{#if utilities.faker}}
"@faker-js/faker": "^{{toolVersions.fakerJs}}",
{{/if}}
"@types/jest": "^29.5.0",
"@types/node": "^20.10.0",
"jest": "^29.7.0",
"ts-jest": "^29.1.0",
"typescript": "^5.3.0",
"eslint": "^8.56.0",
"@typescript-eslint/parser": "^6.19.0",
"@typescript-eslint/eslint-plugin": "^6.19.0",
"jest-playwright-preset": "^3.0.1",
{{#if (eq reportingTool "allure")}}
"jest-allure2-reporter": "^2.2.0",
"allure-commandline": "^2.27.0",
{{/if}}
{{#if (eq reportingTool "jest-html")}}
"jest-html-reporter": "^3.10.2",
{{/if}}
{{#if (eq cloudDeviceFarm "browserstack")}}
"browserstack-node-sdk": "^1.34.15",
{{/if}}
"jest-circus": "^29.7.0"
}
}