import { By, WebDriver } from 'selenium-webdriver';
import { BasePage } from './BasePage';
import envConfig from '../config/env.config';

export class HomePage extends BasePage {
  private readonly url: string;
  private readonly logo = By.css('.logo');
  private readonly userMenu = By.css('.user-menu');
  private readonly logoutButton = By.linkText('Logout');
  private readonly welcomeMessage = By.css('.welcome-message');

  constructor(driver: WebDriver) {
    super(driver);
    this.url = `${envConfig.getBaseUrl()}/dashboard`;
  }

  async navigateToHome(): Promise<void> {
    await this.navigate(this.url);
  }

  async isLoaded(): Promise<boolean> {
    return this.isDisplayed(this.logo);
  }

  async getWelcomeMessage(): Promise<string> {
    return this.getText(this.welcomeMessage);
  }

  async logout(): Promise<void> {
    await this.click(this.userMenu);
    await this.click(this.logoutButton);
  }

  async isUserLoggedIn(): Promise<boolean> {
    return this.isDisplayed(this.userMenu);
  }
}
